# SEO Workflow SaaS - 环境变量配置
# 所有变量都是可选的，代码可以在没有这些变量的情况下运行

# 服务器配置
PORT=8000
HOST=0.0.0.0

# ============ 可选配置 ============
# 以下变量都是可选的，不设置也能正常运行

# Google Custom Search API（可选）
# 如果设置了，会使用真实搜索数据
# 申请地址: https://console.cloud.google.com/
# GOOGLE_API_KEY=your_google_api_key_here
# GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# 百度搜索API（可选）
# BAIDU_API_KEY=your_baidu_api_key_here

# 数据库（可选，用于缓存）
# DATABASE_URL=sqlite:///./seo_cache.db
